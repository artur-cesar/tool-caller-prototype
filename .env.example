PORT=3000

ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-haiku-4-5

# Local host execution:
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=tool_caller_prototype

# Docker Compose overrides DB_HOST to "postgres" for the app container.
# Optional: disable the database connection during test runs or local experiments.
DATABASE_ENABLED=true
